<body>
    <div class="container">
        <h1>🎮 Jogo da Forca - PHP + JavaScript</h1>
        
        <div>
            <span class="tab active" onclick="showTab(0)">Versão PHP (Server)</span>
            <span class="tab" onclick="showTab(1)">Versão JS (Client)</span>
        </div>

        <!-- ==================== VERSÃO PHP ==================== -->
        <div id="tab0">
            <h2>Versão PHP (Server-side)</h2>
            <div class="forca"><?php echo $palavra_exibida_php; ?></div>
            <p>Erros: <?php echo $erros; ?>/<?php echo $max_erros; ?></p>

            <?php if ($game_over_php): ?>
                <h2>💀 Game Over! A palavra era: <strong><?php echo $palavra; ?></strong></h2>
            <?php elseif ($vitoria_php): ?>
                <h2>🎉 Parabéns! Você venceu!</h2>
            <?php else: ?>
                <form method="post">
                    <input type="text" name="letra_php" maxlength="1" required autofocus>
                    <button type="submit">Enviar Letra (PHP)</button>
                </form>
            <?php endif; ?>

            <form method="post">
                <button type="submit" name="reset" value="1">Novo Jogo</button>
            </form>
        </div>

        <!-- ==================== VERSÃO JAVASCRIPT ==================== -->
        <div id="tab1" style="display:none;">
            <h2>Versão JavaScript (Client-side)</h2>
            <canvas id="canvas" width="250" height="280" style="border:2px solid #333; background:white;"></canvas>
            <div id="palavra_js" class="forca"></div>
            <p id="erros_js">Erros: 0/6</p>
            
            <input type="text" id="letra_js" maxlength="1" placeholder="Digite uma letra">
            <button onclick="adivinharJS()">Adivinhar (JS)</button>
            <button onclick="novoJogoJS()">Novo Jogo</button>
        </div>
    </div>

    <script>
        // ==================== LÓGICA JAVASCRIPT ====================
        let palavraJS = '';
        let letrasAdivinhadasJS = [];
        let errosJS = 0;
        const maxErrosJS = 6;
        let canvas, ctx;

        const palavras = ["php", "javascript", "forca", "programacao", "desenvolvimento", "computador", "algoritmo", "html", "css", "mysql"];

        function iniciarJogoJS() {
            palavraJS = palavras[Math.floor(Math.random() * palavras.length)];
            letrasAdivinhadasJS = [];
            errosJS = 0;
            canvas = document.getElementById('canvas');
            ctx = canvas.getContext('2d');
            atualizarTelaJS();
        }

        function desenharForcaJS() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            ctx.strokeStyle = '#333';
            ctx.lineWidth = 8;

            // Base, poste e corda
            ctx.beginPath();
            ctx.moveTo(30, 250); ctx.lineTo(220, 250); ctx.stroke();
            ctx.moveTo(60, 250); ctx.lineTo(60, 40); ctx.stroke();
            ctx.moveTo(60, 40); ctx.lineTo(160, 40); ctx.stroke();
            ctx.moveTo(160, 40); ctx.lineTo(160, 80); ctx.stroke();

            if (errosJS >= 1) { ctx.beginPath(); ctx.arc(160, 105, 20, 0, Math.PI*2); ctx.stroke(); } // cabeça
            if (errosJS >= 2) { ctx.moveTo(160,125); ctx.lineTo(160,200); ctx.stroke(); } // corpo
            if (errosJS >= 3) { ctx.moveTo(160,140); ctx.lineTo(120,170); ctx.stroke(); } // braço esq
            if (errosJS >= 4) { ctx.moveTo(160,140); ctx.lineTo(200,170); ctx.stroke(); } // braço dir
            if (errosJS >= 5) { ctx.moveTo(160,200); ctx.lineTo(130,240); ctx.stroke(); } // perna esq
            if (errosJS >= 6) { ctx.moveTo(160,200); ctx.lineTo(190,240); ctx.stroke(); } // perna dir
        }

        function atualizarTelaJS() {
            desenharForcaJS();
            let exibida = '';
            let completa = true;
            for (let letra of palavraJS) {
                if (letrasAdivinhadasJS.includes(letra)) {
                    exibida += letra + ' ';
                } else {
                    exibida += '_ ';
                    completa = false;
                }
            }
            document.getElementById('palavra_js').textContent = exibida.trim();
            document.getElementById('erros_js').textContent = `Erros: ${errosJS}/${maxErrosJS}`;

            if (errosJS >= maxErrosJS) {
                setTimeout(() => alert('💀 Game Over! A palavra era: ' + palavraJS), 150);
            } else if (completa) {
                setTimeout(() => alert('🎉 Parabéns! Você venceu!'), 150);
            }
        }

        function adivinharJS() {
            const input = document.getElementById('letra_js');
            let letra = input.value.toLowerCase().trim();
            input.value = '';

            if (letra.length === 1 && /^[a-z]$/.test(letra) && !letrasAdivinhadasJS.includes(letra)) {
                letrasAdivinhadasJS.push(letra);
                if (!palavraJS.includes(letra)) errosJS++;
                atualizarTelaJS();
            }
        }

        function novoJogoJS() {
            iniciarJogoJS();
        }

        // Alternar abas
        function showTab(n) {
            document.getElementById('tab0').style.display = n === 0 ? 'block' : 'none';
            document.getElementById('tab1').style.display = n === 1 ? 'block' : 'none';
            
            document.querySelectorAll('.tab').forEach((tab, i) => {
                tab.classList.toggle('active', i === n);
            });

            if (n === 1) novoJogoJS();
        }

        // Iniciar JS automaticamente na primeira vez
        window.onload = () => {
            showTab(0); // Começa na aba PHP
        };
    </script>
</body>
</html>

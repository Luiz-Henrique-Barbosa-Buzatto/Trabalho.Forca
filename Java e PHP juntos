<?php
session_start();

// ==================== LÓGICA PHP (Server-side) ====================
$palavras = ["php", "javascript", "forca", "programacao", "desenvolvimento", "computador", "algoritmo", "html", "css", "mysql"];

if (!isset($_SESSION['palavra'])) {
    $_SESSION['palavra'] = $palavras[array_rand($palavras)];
    $_SESSION['letras_adivinhadas'] = [];
    $_SESSION['erros'] = 0;
    $_SESSION['max_erros'] = 6;
}

$palavra = $_SESSION['palavra'];
$letras_adivinhadas = $_SESSION['letras_adivinhadas'];
$erros = $_SESSION['erros'];
$max_erros = $_SESSION['max_erros'];

// Processar palpite via PHP (POST)
if ($_SERVER['REQUEST_METHOD'] === 'POST' && isset($_POST['letra_php'])) {
    $letra = strtolower(trim($_POST['letra_php']));
    if (ctype_alpha($letra) && strlen($letra) === 1 && !in_array($letra, $letras_adivinhadas)) {
        $letras_adivinhadas[] = $letra;
        $_SESSION['letras_adivinhadas'] = $letras_adivinhadas;
        
        if (strpos($palavra, $letra) === false) {
            $_SESSION['erros']++;
        }
    }
}

// Reset
if (isset($_POST['reset'])) {
    session_destroy();
    header("Location: index.php");
    exit;
}

// Preparar palavra exibida (PHP)
$palavra_exibida_php = '';
$completa_php = true;
for ($i = 0; $i < strlen($palavra); $i++) {
    if (in_array($palavra[$i], $letras_adivinhadas)) {
        $palavra_exibida_php .= $palavra[$i] . ' ';
    } else {
        $palavra_exibida_php .= '_ ';
        $completa_php = false;
    }
}
$game_over_php = $erros >= $max_erros;
$vitoria_php = $completa_php && !$game_over_php;
?>

<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="UTF-8">
    <title>Jogo da Forca - PHP + JS</title>
    <style>
        body { 
            font-family: Arial, sans-serif; 
            text-align: center; 
